# Base URL API (default /api/v1 → vite proxy tới :8000). Đổi khi deploy backend riêng.
VITE_API_BASE=/api/v1

# Postgres. Trong Docker compose dùng host `db`. Ngoài Docker (local) dùng localhost:5433.
DATABASE_URL=postgres://wedding:wedding@db:5432/wedding

# Tài khoản admin (đổi mạnh hơn khi public).
ADMIN_USER=
ADMIN_PASS=